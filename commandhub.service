[Unit]
Description=commandhub.iot FastAPI IoT Gateway
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/pi/commandhub.iot
EnvironmentFile=/home/pi/commandhub.iot/.env
ExecStart=/home/pi/commandhub.iot/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
