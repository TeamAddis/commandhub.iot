# MQTT Broker (local Mosquitto on Raspberry Pi)
MQTT_BROKER_HOST=192.168.1.x
MQTT_BROKER_PORT=1883
MQTT_USERNAME=your_mqtt_username
MQTT_PASSWORD=your_mqtt_password

# API Security
API_KEY=your_secret_api_key_here

# MQTT Response Timeout (seconds)
MQTT_RESPONSE_TIMEOUT=5

# /logs page Basic Auth credentials (for browser access to the transaction log UI)
LOGS_USER=your_logs_username
LOGS_PASSWORD=your_logs_password
